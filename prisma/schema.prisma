generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SystemRole {
  SUPER_ADMIN
  TENANT_OWNER
  ADMIN
  MANAGER
  EVENT_MANAGER
  SCANNER_STAFF
  SUPPORT_STAFF
  CUSTOMER

  @@map("Role")
}

enum OrderStatus {
  PENDING
  PARTIALLY_PAID
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum OrderItemType {
  PRODUCT
  TICKET
}

enum TicketStatus {
  VALID
  USED
  VOID
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum PricingRuleType {
  EARLY_BIRD
  INVENTORY_TIER
  LIMITED_TIME
}

enum PaymentMode {
  FULL
  DEPOSIT
  INSTALLMENT
}

enum InstallmentStatus {
  PENDING
  PAID
  FAILED
  CANCELLED
}

enum RefundStatus {
  REQUESTED
  APPROVED
  REJECTED
  PAID
}

enum CampaignStatus {
  DRAFT
  SCHEDULED
  SENT
  CANCELLED
}

enum CampaignAudience {
  ALL_USERS
  EVENT_ATTENDEES
  HIGH_VALUE_CUSTOMERS
  VIP_CUSTOMERS
}

enum NotificationType {
  LOW_STOCK
  TICKETS_LOW
  DAILY_SUMMARY
  ORDER_CONFIRMATION
  EVENT_REMINDER
}

enum EnquiryStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  SPAM
}

model Tenant {
  id              String    @id @default(cuid())
  name            String
  slug            String    @unique
  plan            String    @default("STARTER")
  platformFeeBps  Int       @default(250)
  fixedTicketFeeCents Int   @default(0)
  supportEmail    String?
  whatsappNumber  String?
  active          Boolean   @default(true)
  users           User[]
  roles           Role[]
  products        Product[]
  events          Event[]
  orders          Order[]
  discounts       DiscountCode[]
  bundles         Bundle[]
  campaigns       Campaign[]
  enquiries       Enquiry[]
  notifications   AdminNotification[]
  images          ImageAsset[]
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([active])
}

model User {
  id            String    @id @default(cuid())
  tenantId      String?
  tenant        Tenant?   @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  name          String
  email         String    @unique
  passwordHash  String
  role          SystemRole @default(CUSTOMER)
  phone         String?
  emailVerified DateTime?
  image         String?
  tags          String[]  @default([])
  referralCode  String?   @unique
  referredById  String?
  referredBy    User?     @relation("UserReferrals", fields: [referredById], references: [id], onDelete: SetNull)
  referredUsers User[]    @relation("UserReferrals")
  loyaltyPoints Int       @default(0)
  orders        Order[]
  roles         UserRole[]
  activityLogs  ActivityLog[]
  tickets       Ticket[]
  wishlistItems WishlistItem[]
  reviews       Review[]
  refundRequests RefundRequest[]
  referralsMade Referral[] @relation("ReferralInviter")
  referralsReceived Referral[] @relation("ReferralInvitee")
  loyaltyTransactions LoyaltyTransaction[]
  sessions      Session[]
  accounts      Account[]
  assignedEnquiries Enquiry[]
  uploadedImages ImageAsset[]
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  @@index([tenantId])
  @@index([role])
  @@index([createdAt])
}

model Role {
  id          String           @id @default(cuid())
  name        String
  description String?
  tenantId    String?
  tenant      Tenant?          @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       UserRole[]
  permissions RolePermission[]
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("AccessRole")
}

model Permission {
  id          String           @id @default(cuid())
  name        String           @unique
  description String?
  roles       RolePermission[]
  createdAt   DateTime         @default(now())
}

model UserRole {
  userId    String
  roleId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@id([userId, roleId])
  @@index([roleId])
}

model RolePermission {
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  createdAt    DateTime   @default(now())

  @@id([roleId, permissionId])
  @@index([permissionId])
}

model ActivityLog {
  id            String   @id @default(cuid())
  tenantId      String?
  userId        String?
  user          User?    @relation(fields: [userId], references: [id], onDelete: SetNull)
  action        String
  entityType    String?
  entityId      String?
  metadata      Json?
  createdAt     DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([action])
}

model Product {
  id          String      @id @default(cuid())
  tenantId    String?
  tenant      Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  slug        String      @unique
  name        String
  description String
  priceCents  Int
  stock       Int         @default(0)
  category    String
  images      String[]    @default([])
  featured    Boolean     @default(false)
  active      Boolean     @default(true)
  orderItems  OrderItem[]
  bundleItems BundleItem[]
  wishlistItems WishlistItem[]
  reviews     Review[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@index([tenantId])
  @@index([category])
  @@index([featured, active])
  @@index([createdAt])
}

model Event {
  id          String       @id @default(cuid())
  tenantId    String?
  tenant      Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  slug        String       @unique
  title       String
  description String
  startsAt    DateTime
  location    String
  bannerImage String
  featured    Boolean      @default(false)
  published   Boolean      @default(true)
  ticketTypes TicketType[]
  tickets     Ticket[]
  orderItems  OrderItem[]
  pricingRules PricingRule[]
  bundleItems BundleItem[]
  reviews     Review[]
  wishlists   WishlistItem[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([tenantId])
  @@index([startsAt])
  @@index([published, featured])
}

model TicketType {
  id             String      @id @default(cuid())
  eventId        String
  event          Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  name           String
  description    String?
  priceCents     Int
  quantity       Int
  sold           Int         @default(0)
  active         Boolean     @default(true)
  orderItems     OrderItem[]
  tickets        Ticket[]
  pricingRules   PricingRule[]
  bundleItems    BundleItem[]
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  @@index([eventId])
  @@index([active])
}

model Ticket {
  id           String       @id @default(cuid())
  code         String       @unique
  qrPayload    String       @unique
  qrImage      String?
  status       TicketStatus @default(VALID)
  userId       String?
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  eventId      String
  event        Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketTypeId String
  ticketType   TicketType   @relation(fields: [ticketTypeId], references: [id], onDelete: Restrict)
  orderId      String?
  order        Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  holderName   String?
  holderEmail  String?
  usedAt       DateTime?
  transferredAt DateTime?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  @@index([eventId, status])
  @@index([userId])
  @@index([orderId])
}

model Order {
  id                    String      @id @default(cuid())
  tenantId              String?
  tenant                Tenant?     @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  orderNumber           String      @unique
  status                OrderStatus @default(PENDING)
  paymentMode           PaymentMode @default(FULL)
  currency              String      @default("ZAR")
  subtotalCents         Int
  discountCents         Int         @default(0)
  platformFeeCents      Int         @default(0)
  totalCents            Int
  amountPaidCents       Int         @default(0)
  balanceDueCents       Int         @default(0)
  stripeCheckoutId      String?     @unique
  stripePaymentIntentId String?     @unique
  customerName          String
  customerEmail         String
  userId                String?
  user                  User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  discountCodeId        String?
  discountCode          DiscountCode? @relation(fields: [discountCodeId], references: [id], onDelete: SetNull)
  items                 OrderItem[]
  tickets               Ticket[]
  installments          PaymentInstallment[]
  loyaltyTransactions   LoyaltyTransaction[]
  refundRequests        RefundRequest[]
  paidAt                DateTime?
  createdAt             DateTime    @default(now())
  updatedAt             DateTime    @updatedAt

  @@index([tenantId])
  @@index([status, createdAt])
  @@index([customerEmail])
  @@index([userId])
}

model OrderItem {
  id              String        @id @default(cuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type            OrderItemType
  name            String
  quantity        Int
  unitPriceCents  Int
  totalPriceCents Int
  productId       String?
  product         Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  eventId         String?
  event           Event?        @relation(fields: [eventId], references: [id], onDelete: SetNull)
  ticketTypeId    String?
  ticketType      TicketType?   @relation(fields: [ticketTypeId], references: [id], onDelete: SetNull)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  @@index([orderId])
  @@index([productId])
  @@index([ticketTypeId])
}

model DiscountCode {
  id          String       @id @default(cuid())
  tenantId    String?
  tenant      Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  code        String       @unique
  type        DiscountType
  value       Int
  active      Boolean      @default(true)
  startsAt    DateTime?
  expiresAt   DateTime?
  usageLimit  Int?
  usedCount   Int          @default(0)
  orders      Order[]
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  @@index([tenantId])
  @@index([active, expiresAt])
}

model PricingRule {
  id             String          @id @default(cuid())
  type           PricingRuleType
  name           String
  active         Boolean         @default(true)
  startsAt       DateTime?
  endsAt         DateTime?
  threshold      Int?
  priceCents     Int?
  discountBps    Int?
  eventId        String?
  event          Event?          @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketTypeId   String?
  ticketType     TicketType?     @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([active, type])
  @@index([eventId])
  @@index([ticketTypeId])
}

model Bundle {
  id             String       @id @default(cuid())
  tenantId       String?
  tenant         Tenant?      @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  name           String
  slug           String       @unique
  description    String?
  discountBps    Int         @default(0)
  active         Boolean      @default(true)
  items          BundleItem[]
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  @@index([tenantId, active])
}

model BundleItem {
  id           String      @id @default(cuid())
  bundleId     String
  bundle       Bundle      @relation(fields: [bundleId], references: [id], onDelete: Cascade)
  productId    String?
  product      Product?    @relation(fields: [productId], references: [id], onDelete: Cascade)
  eventId      String?
  event        Event?      @relation(fields: [eventId], references: [id], onDelete: Cascade)
  ticketTypeId String?
  ticketType   TicketType? @relation(fields: [ticketTypeId], references: [id], onDelete: Cascade)
  quantity     Int         @default(1)

  @@index([bundleId])
  @@index([productId])
  @@index([ticketTypeId])
}

model PaymentInstallment {
  id                    String            @id @default(cuid())
  orderId               String
  order                 Order             @relation(fields: [orderId], references: [id], onDelete: Cascade)
  sequence              Int
  amountCents           Int
  dueAt                 DateTime?
  status                InstallmentStatus @default(PENDING)
  stripePaymentIntentId String?
  paidAt                DateTime?
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@unique([orderId, sequence])
  @@index([status, dueAt])
}

model Referral {
  id             String   @id @default(cuid())
  code           String   @unique
  inviterId      String
  inviter        User     @relation("ReferralInviter", fields: [inviterId], references: [id], onDelete: Cascade)
  inviteeId      String?
  invitee        User?    @relation("ReferralInvitee", fields: [inviteeId], references: [id], onDelete: SetNull)
  rewardCents    Int      @default(0)
  redeemed       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([inviterId])
  @@index([inviteeId])
}

model LoyaltyTransaction {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  orderId     String?
  order       Order?   @relation(fields: [orderId], references: [id], onDelete: SetNull)
  points      Int
  reason      String
  createdAt   DateTime @default(now())

  @@index([userId, createdAt])
  @@index([orderId])
}

model WishlistItem {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  eventId     String?
  event       Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt   DateTime @default(now())

  @@unique([userId, productId])
  @@unique([userId, eventId])
  @@index([userId])
}

model Review {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  productId   String?
  product     Product? @relation(fields: [productId], references: [id], onDelete: Cascade)
  eventId     String?
  event       Event?   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  rating      Int
  comment     String?
  approved    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([productId, approved])
  @@index([eventId, approved])
  @@index([userId])
}

model RefundRequest {
  id            String       @id @default(cuid())
  orderId       String
  order         Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  userId        String?
  user          User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  reason        String
  status        RefundStatus @default(REQUESTED)
  amountCents   Int?
  adminNote     String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt

  @@index([status, createdAt])
  @@index([orderId])
}

model Campaign {
  id          String           @id @default(cuid())
  tenantId    String?
  tenant      Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  name        String
  subject     String
  body        String
  audience    CampaignAudience @default(ALL_USERS)
  status      CampaignStatus   @default(DRAFT)
  sentAt      DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([tenantId, status])
}

model AdminNotification {
  id          String           @id @default(cuid())
  tenantId    String?
  tenant      Tenant?          @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  type        NotificationType
  title       String
  message     String
  read        Boolean          @default(false)
  createdAt   DateTime         @default(now())

  @@index([tenantId, read, createdAt])
}

model Visit {
  id          String   @id @default(cuid())
  path        String
  sessionKey  String?
  userId      String?
  createdAt   DateTime @default(now())

  @@index([path, createdAt])
  @@index([sessionKey])
}

model ImageAsset {
  id          String   @id @default(cuid())
  tenantId    String?
  tenant      Tenant?  @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  uploadedById String?
  uploadedBy  User?    @relation(fields: [uploadedById], references: [id], onDelete: SetNull)
  filename    String
  mimeType    String
  size        Int
  data        Bytes
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([tenantId])
  @@index([uploadedById])
  @@index([createdAt])
}

model Enquiry {
  id           String        @id @default(cuid())
  tenantId     String?
  tenant       Tenant?       @relation(fields: [tenantId], references: [id], onDelete: SetNull)
  name         String
  email        String
  phone        String?
  subject      String
  message      String
  channel      String        @default("WEBSITE")
  status       EnquiryStatus @default(NEW)
  assignedToId String?
  assignedTo   User?         @relation(fields: [assignedToId], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  @@index([tenantId])
  @@index([status, createdAt])
  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
