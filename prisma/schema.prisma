generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  USER
  ADMIN
  STAFF
}

enum TicketStatus {
  VALID
  USED
  VOID
}

enum OrderStatus {
  AWAITING_PAYMENT
  PAID
  FAILED
  CANCELLED
  FULFILLED
  REFUNDED
}

enum OrderType {
  TICKET
  PRODUCT
  MIXED
}

enum OrderItemType {
  TICKET
  PRODUCT
}

enum DiscountType {
  PERCENTAGE
  FIXED
}

enum SocialSource {
  FACEBOOK
  INSTAGRAM
  MANUAL
}

enum EnquiryStatus {
  NEW
  IN_PROGRESS
  RESOLVED
  SPAM
}

enum EnquiryType {
  GENERAL
  TICKETS
  MERCH
  EVENT_BOOKING
  SPONSORSHIP
  SUPPORT
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  role          Role      @default(USER)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt

  accounts      Account[]
  sessions      Session[]
  orders        Order[]
  tickets       Ticket[]
  createdEvents Event[]    @relation("CreatedEvents")
  checkedTickets Ticket[]   @relation("CheckedTickets")
  createdEnquiries Enquiry[]
}

model Event {
  id                String       @id @default(cuid())
  slug              String       @unique
  title             String
  description       String
  location          String
  venue             String?
  address           String?
  startsAt          DateTime
  endsAt            DateTime?
  ticketPriceCents  Int
  currency          String       @default("ZAR")
  capacity          Int?
  imageUrl          String
  galleryUrls       String[]     @default([])
  tags              String[]     @default([])
  featured          Boolean      @default(false)
  published         Boolean      @default(true)
  schedule          Json?
  createdById       String?
  createdBy         User?        @relation("CreatedEvents", fields: [createdById], references: [id], onDelete: SetNull)
  tickets           Ticket[]
  orderItems        OrderItem[]
  galleryImages     GalleryImage[]
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt
}

model Ticket {
  id             String       @id @default(cuid())
  code           String       @unique
  qrPayload      String       @unique
  qrImageUrl     String?
  status         TicketStatus @default(VALID)
  eventId        String
  event          Event        @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId         String?
  user           User?        @relation(fields: [userId], references: [id], onDelete: SetNull)
  orderId        String?
  order          Order?       @relation(fields: [orderId], references: [id], onDelete: SetNull)
  holderName     String?
  holderEmail    String?
  checkedInById  String?
  checkedInBy    User?        @relation("CheckedTickets", fields: [checkedInById], references: [id], onDelete: SetNull)
  usedAt         DateTime?
  notes          String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt
}

model Order {
  id                   String      @id @default(cuid())
  orderNumber          String      @unique
  type                 OrderType   @default(MIXED)
  status               OrderStatus @default(AWAITING_PAYMENT)
  currency             String      @default("ZAR")
  subtotalCents        Int
  discountCents       Int         @default(0)
  totalCents           Int
  paygateReference     String?     @unique
  paygateRequestId     String?
  paygateTransactionId String?
  paygateResultCode    String?
  paygateResultDesc    String?
  customerName         String
  customerEmail        String
  customerPhone       String?
  shippingAddress     Json?
  notes               String?
  userId              String?
  user                User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  discountCodeId      String?
  discountCode        DiscountCode? @relation(fields: [discountCodeId], references: [id], onDelete: SetNull)
  items               OrderItem[]
  tickets             Ticket[]
  paidAt              DateTime?
  fulfilledAt         DateTime?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
}

model OrderItem {
  id              String        @id @default(cuid())
  orderId         String
  order           Order         @relation(fields: [orderId], references: [id], onDelete: Cascade)
  type            OrderItemType
  name            String
  quantity        Int
  unitPriceCents  Int
  totalPriceCents Int
  eventId         String?
  event           Event?        @relation(fields: [eventId], references: [id], onDelete: SetNull)
  productId       String?
  product         Product?      @relation(fields: [productId], references: [id], onDelete: SetNull)
  metadata        Json?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
}

model Product {
  id                   String        @id @default(cuid())
  slug                 String        @unique
  name                 String
  description          String
  priceCents           Int
  compareAtPriceCents  Int?
  category             String
  inventory            Int           @default(0)
  featured             Boolean       @default(false)
  active               Boolean       @default(true)
  imageUrl             String
  galleryUrls          String[]      @default([])
  orderItems           OrderItem[]
  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @updatedAt
}

model GalleryImage {
  id            String   @id @default(cuid())
  title         String
  slug          String   @unique
  description   String?
  imageUrl      String
  downloadUrl   String?
  altText       String?
  eventId       String?
  event         Event?   @relation(fields: [eventId], references: [id], onDelete: SetNull)
  featured      Boolean  @default(false)
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Testimonial {
  id            String   @id @default(cuid())
  name          String
  role          String?
  quote         String
  avatarUrl     String?
  rating        Int      @default(5)
  featured      Boolean  @default(false)
  published     Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model SocialPost {
  id            String       @id @default(cuid())
  source        SocialSource  @default(FACEBOOK)
  externalId    String?       @unique
  message       String
  link          String?
  imageUrl      String?
  authorName    String?
  publishedAt   DateTime
  syncedAt      DateTime      @default(now())
  featured      Boolean       @default(false)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Enquiry {
  id           String        @id @default(cuid())
  type         EnquiryType   @default(GENERAL)
  status       EnquiryStatus @default(NEW)
  name         String
  email        String
  phone        String?
  subject      String
  message      String
  source       String        @default("WEBSITE")
  notes        String?
  resolvedAt   DateTime?
  createdById  String?
  createdBy    User?         @relation(fields: [createdById], references: [id], onDelete: SetNull)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
}

model DiscountCode {
  id            String        @id @default(cuid())
  code          String        @unique
  description   String?
  type          DiscountType
  value         Int
  active        Boolean       @default(true)
  usageLimit    Int?
  usedCount     Int           @default(0)
  expiresAt     DateTime?
  orders        Order[]
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId  String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?
  oauth_token_secret String? @db.Text
  oauth_token       String? @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}
